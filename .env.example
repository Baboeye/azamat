# Environment variables for Railway deployment

# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=material-accounting.up.railway.app,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://material-accounting.up.railway.app,https://localhost:8000,http://localhost:8000

# Database
# Railway automatically provides DATABASE_URL for PostgreSQL
# DATABASE_URL=postgresql://user:password@host:port/dbname

# For local development, you can use SQLite:
# DATABASE_URL=sqlite:///db.sqlite3

# Notes for Railway deployment:
# 1. Generate SECRET_KEY with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# 2. Change material-accounting to your actual Railway app name (from URL)
# 3. Railway automatically sets DATABASE_URL, no need to configure it

